{
  "name": "go-cpabe-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "CP-ABE 加密文件共享系统桌面端基础工程",
  "main": "dist/main/main.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev:web": "vite --host 127.0.0.1",
    "dev:web:scnu": "cross-env VITE_DEFAULT_TENANT_CODE=scnu npm run dev:web",
    "dev:web:sangfor": "cross-env VITE_DEFAULT_TENANT_CODE=sangfor npm run dev:web",
    "dev:web:aia": "cross-env VITE_DEFAULT_TENANT_CODE=aia-hk npm run dev:web",
    "dev:electron": "npm run build && electron dist/main/main.js",
    "dev:electron:scnu": "cross-env VITE_DEFAULT_TENANT_CODE=scnu npm run dev:electron",
    "dev:electron:sangfor": "cross-env VITE_DEFAULT_TENANT_CODE=sangfor npm run dev:electron",
    "dev:electron:aia": "cross-env VITE_DEFAULT_TENANT_CODE=aia-hk npm run dev:electron",
    "dev": "npm run dev:electron",
    "dev:scnu": "npm run dev:electron:scnu",
    "dev:sangfor": "npm run dev:electron:sangfor",
    "dev:aia": "npm run dev:electron:aia",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
