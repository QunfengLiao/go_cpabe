{
  "name": "go-cpabe-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "CP-ABE 加密文件共享系统桌面端基础工程",
  "main": "dist/main/main.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev": "npm run build && electron dist/main/main.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
