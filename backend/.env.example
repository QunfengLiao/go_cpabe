MYSQL_DSN=cpabe:cpabe@tcp(127.0.0.1:3306)/go_cpabe?charset=utf8mb4&parseTime=True&loc=Local
APP_ENV=development
RUN_AUTO_MIGRATE=false
RUN_SEED=false
RUN_DEMO_SEED=false
# 兼容旧配置；建议改用 RUN_DEMO_SEED。
SEED_DEMO_DATA=false
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET=please-change-this-secret-in-real-env
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
SERVER_ADDR=:8080
AVATAR_UPLOAD_DIR=uploads/avatars
AVATAR_URL_PREFIX=/uploads/avatars
AVATAR_MAX_SIZE=2097152
ENCRYPTED_FILE_STORAGE_DIR=uploads/ciphertexts
ENCRYPTED_FILE_TEMP_DIR=uploads/ciphertexts/.staging
ENCRYPTED_FILE_MAX_SIZE=1073741824
ENCRYPTION_MAX_CONCURRENT_PER_TENANT=3
ENCRYPTION_STAGING_TTL=24h

# 审计 Dispatcher 每次执行一批后退出，建议由计划任务重复调度。
# 租约必须覆盖正常单批处理时间；重试采用带上限的指数退避，死信不会被保留期自动删除。
AUDIT_DISPATCH_BATCH_SIZE=100
AUDIT_DISPATCH_LEASE=1m
AUDIT_DISPATCH_MAX_RETRIES=10
AUDIT_DISPATCH_BASE_BACKOFF=30s
AUDIT_DISPATCH_MAX_BACKOFF=1h
AUDIT_DELIVERED_RETENTION=168h
